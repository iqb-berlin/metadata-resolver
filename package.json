{
  "name": "@iqb/metadata-resolver",
  "version": "0.1.0",
  "description": "Framework-agnostic metadata and vocabulary resolver for IQB metadata profiles",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsdown src/index.ts --format cjs,esm --dts --watch"
  },
  "keywords": [
    "metadata",
    "vocabulary",
    "resolver",
    "iqb"
  ],
  "author": "IQB",
  "license": "MIT",
  "dependencies": {
    "@iqb/metadata": "^1.4.1"
  },
  "devDependencies": {
    "tsdown": "^0.20.0-beta.2",
    "typescript": "^5.3.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
